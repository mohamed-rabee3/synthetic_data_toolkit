# ─────────────────────────────────────────────────────────────
# Provider for GENERATION role: "gemini" or "ollama"
# Set to "ollama" to run the full pipeline on Ollama only.
# ─────────────────────────────────────────────────────────────
GENERATION_PROVIDER=gemini

# ─────────────────────────────────────────────────────────────
# Gemini settings (only used when GENERATION_PROVIDER=gemini)
# Mode: "ai_studio" (API key) or "vertex_ai" (GCP project)
# ─────────────────────────────────────────────────────────────
GEMINI_MODE=ai_studio
GOOGLE_API_KEY=

# Vertex AI only
# NOTE: GOOGLE_GENAI_USE_VERTEXAI is managed automatically from GEMINI_MODE. Don't set it here.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# ─────────────────────────────────────────────────────────────
# Ollama settings (used for judge role always; also generation if GENERATION_PROVIDER=ollama)
# Mode: "local" or "cloud"
# ─────────────────────────────────────────────────────────────
OLLAMA_MODE=local
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3

# Cloud only — get your key at https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Generation-specific Ollama model override (optional).
# If set, the generation role uses this model while the judge role keeps OLLAMA_MODEL.
# Useful when you want a bigger model for generation and a smaller one for judging.
# OLLAMA_GENERATION_MODEL=gpt-oss:120b-cloud

# ─────────────────────────────────────────────────────────────
# Pipeline settings (optional overrides of pipeline.yaml)
# ─────────────────────────────────────────────────────────────
# PIPELINE_DOMAIN_CONTEXT=هذه وثائق لشركة تقنية سعودية متخصصة في حلول الدفع الإلكتروني
# LOG_LEVEL=INFO
